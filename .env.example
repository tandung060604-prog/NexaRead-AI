# Application
APP_ENV=development
APP_NAME=NexaRead API
SERVICE_NAME=nexaread-api

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=50

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Local infrastructure
POSTGRES_DB=nexaread
POSTGRES_USER=nexaread
POSTGRES_PASSWORD=nexaread-dev
POSTGRES_PORT=5432
REDIS_PORT=6379
S3_PORT=9000
S3_CONSOLE_PORT=9001

# Local document ownership until authentication is implemented.
DEFAULT_OWNER_ID=local-user

# S3-compatible object storage. These are local MinIO development values only.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexaread-minio
S3_SECRET_KEY=nexaread-minio-dev
S3_BUCKET=nexaread-documents
S3_REGION=us-east-1
MAX_UPLOAD_SIZE_MB=50
URL_IMPORT_MAX_MB=10
URL_IMPORT_TIMEOUT_SECONDS=10
URL_IMPORT_MAX_REDIRECTS=3
PARSER_TIMEOUT_SECONDS=60
MIN_EXTRACTED_TEXT_CHARACTERS=20

# Grounded RAG. The local provider is deterministic and requires no secret.
# Set RAG_PROVIDER=openai and provide OPENAI_API_KEY for hosted embeddings/answers.
RAG_PROVIDER=local
OPENAI_API_KEY=
OPENAI_BASE_URL=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=384
RAG_ANSWER_MODEL=gpt-5-mini
RAG_TOP_K=8
RAG_EVIDENCE_THRESHOLD=0.08
RAG_PROVIDER_TIMEOUT_SECONDS=30
AI_RATE_LIMIT_PER_MINUTE=30
RAG_RERANK_TIMEOUT_SECONDS=0.25
RAG_INPUT_COST_PER_MILLION=0
RAG_OUTPUT_COST_PER_MILLION=0

# Use localhost when running the backend outside Docker.
DATABASE_URL=postgresql+asyncpg://nexaread:nexaread-dev@localhost:5432/nexaread
REDIS_URL=redis://localhost:6379/0
